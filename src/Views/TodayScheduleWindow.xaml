<Window x:Class="todochart.Views.TodayScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:todochart.ViewModels"
        xmlns:ctrl="clr-namespace:todochart.Controls"
        xmlns:conv="clr-namespace:todochart.Converters"
        xmlns:win="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="&#20170;&#26085;&#12398;&#20104;&#23450;"
        Width="560" Height="480" MinWidth="360" MinHeight="200"
        Background="{DynamicResource WindowBgBrush}"
        Foreground="{DynamicResource WindowFgBrush}"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="Meiryo UI, Segoe UI, sans-serif" FontSize="13"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <!-- WindowChrome を設定して WindowStyle=None のままリサイズを可能にする -->
    <win:WindowChrome.WindowChrome>
        <win:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </win:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TransparentWindowStyle" TargetType="Window">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="WindowStyle" Value="None"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding CopyItemCommand}"/>
        <KeyBinding Key="X" Modifiers="Ctrl" Command="{Binding CutItemCommand}"/>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding PasteItemCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- カスタムタイトルバー -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Height="25" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Image Source="/snowflake.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" Foreground="{DynamicResource WindowFgBrush}" FontSize="13"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="BtnMin" Click="OnMinimizeClick" Width="40" Height="24" Style="{DynamicResource ToolBarButtonStyle}" ToolTip="最小化">▁</Button>
                    <Button x:Name="BtnMax" Click="OnMaximizeRestoreClick" Width="40" Height="24" Style="{DynamicResource ToolBarButtonStyle}" ToolTip="最大化">▢</Button>
                    <Button x:Name="BtnClose" Click="OnCloseClick" Width="40" Height="24" Style="{DynamicResource ToolBarButtonStyle}" ToolTip="閉じる">✕</Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Height="{DynamicResource HeaderHeight}"
                Background="{DynamicResource HeaderBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid x:Name="TaskHeaderGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ColMark"   Width="36" MinWidth="28"/>
                    <ColumnDefinition x:Name="ColName"   Width="*"  MinWidth="100"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition x:Name="ColStatus" Width="80" MinWidth="40"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition x:Name="ColML"     Width="36" MinWidth="28"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Command="{Binding ToggleStarFilterCommand}"
                        ToolTip="{Binding StarFilterTooltip}"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Center"
                        Padding="0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding StarFilterGlyph}" Style="{DynamicResource ColumnHeaderStyle}" HorizontalAlignment="Center"
                               Foreground="{Binding StarFilterBrush, Mode=OneWay}"/>
                </Button>
                <TextBlock Grid.Column="1" Text="&#12479;&#12473;&#12463;&#21517;"
                           Style="{DynamicResource ColumnHeaderStyle}"/>
                <GridSplitter Grid.Column="2" Width="4" HorizontalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeWE"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"/>
                <TextBlock Grid.Column="3" Text="&#29366;&#24907;"
                           Style="{DynamicResource ColumnHeaderStyle}"/>
                <GridSplitter Grid.Column="4" Width="4" HorizontalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeWE"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"/>
                <TextBlock Grid.Column="5" Text="ML"
                           Style="{DynamicResource ColumnHeaderStyle}"/>
            </Grid>
        </Border>

        <ListBox x:Name="TaskListBox" Grid.Row="2"
                 ItemsSource="{Binding TodayItems}"
                 SelectedItem="{Binding Selected, Mode=TwoWay}"
                 Background="{DynamicResource WindowBgBrush}" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.ScrollUnit="Pixel"
                 ItemContainerStyle="{DynamicResource TaskRowContainerStyle}"
                 MouseDoubleClick="OnListBoxMouseDoubleClick"
                 PreviewKeyDown="OnTaskListPreviewKeyDown">

            <ListBox.InputBindings>
                <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding CopyItemCommand}"/>
                <KeyBinding Key="X" Modifiers="Ctrl" Command="{Binding CutItemCommand}"/>
                <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding PasteItemCommand}"/>
                <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteCommand}"/>
                <KeyBinding Key="Space" Modifiers="Ctrl" Command="{Binding Selected.ToggleMarkCommand}"/>
                <KeyBinding Key="OemSemicolon" Modifiers="Control" Command="{Binding IncreaseProgressCommand}"/>
                <KeyBinding Key="Oem1" Modifiers="Control" Command="{Binding IncreaseProgressCommand}"/>
                <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding IncreaseProgressCommand}"/>
                <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding DecreaseProgressCommand}"/>
                <KeyBinding Key="Subtract" Modifiers="Control" Command="{Binding DecreaseProgressCommand}"/>
                <KeyBinding Key="M" Modifiers="Control" Command="{Binding EditOnMemoCommand}"/>
                <KeyBinding Key="L" Modifiers="Control" Command="{Binding Selected.OpenLinkCommand}"/>
                <KeyBinding Key="F" Modifiers="Control" Command="{Binding IncreaseProgressCommand}"/>
                <KeyBinding Key="B" Modifiers="Control" Command="{Binding DecreaseProgressCommand}"/>
                <KeyBinding Key="F" Modifiers="Control+Shift" Command="{Binding ShiftEndPlusCommand}"/>
                <KeyBinding Key="B" Modifiers="Control+Shift" Command="{Binding ShiftEndMinusCommand}"/>
            </ListBox.InputBindings>

            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding ContextCompleteHeader}"
                              Command="{Binding ToggleCompleteCommand}"
                              IsEnabled="{Binding IsContextCompleteEnabled}"/>
                    <MenuItem Header="{Binding ContextWaitHeader}"
                              Command="{Binding ToggleWaitCommand}"
                              IsEnabled="{Binding IsContextWaitEnabled}"/>
                    <Separator/>
                    <MenuItem Header="&#26032;&#35215;&#12479;&#12473;&#12463;(_T)"
                              Command="{Binding NewToDoCommand}"/>
                    <MenuItem Header="&#26032;&#35215;&#12501;&#12457;&#12523;&#12480;(_F)"
                              Command="{Binding NewFolderCommand}"/>
                    <Separator/>
                    <MenuItem Header="コピー(_C)"       Command="{Binding CopyItemCommand}"  InputGestureText="Ctrl+C"/>
                    <MenuItem Header="切り取り(_X)"     Command="{Binding CutItemCommand}"   InputGestureText="Ctrl+X"/>
                    <MenuItem Header="貼り付け(_V)"     Command="{Binding PasteItemCommand}" InputGestureText="Ctrl+V"/>
                    <Separator/>
                    <MenuItem Header="&#21066;&#38500;(_D)"
                              Command="{Binding DeleteCommand}"
                              InputGestureText="Ctrl+D"/>
                    <Separator/>
                    <MenuItem Header="アーカイブ(_A)"
                              Command="{Binding ArchiveCommand}"/>
                </ContextMenu>
            </ListBox.ContextMenu>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TaskRowViewModel}">
                    <Border Background="{Binding RowBackground}"
                            BorderBrush="#15000000" BorderThickness="0,0,0,1"
                            Height="{DynamicResource RowHeight}">
                        <Grid>
                            <!-- 選択色オーバーレイ（ヒットテスト無効にして下の操作を妨げない） -->
                            <Border Background="{DynamicResource RowSelectedBrush}"
                                    BorderBrush="#FFADD6FF"
                                    BorderThickness="0,1,0,1"
                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}"
                                    IsHitTestVisible="False"/>
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=ColMark,   Path=Width}"/>
                                <ColumnDefinition Width="{Binding ElementName=ColName,   Path=Width}"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="{Binding ElementName=ColStatus, Path=Width}"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="{Binding ElementName=ColML,     Path=Width}"/>
                            </Grid.ColumnDefinitions>
                            <!-- マーク列 -->
                            <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Command="{Binding ToggleMarkCommand}"
                                        Width="24" Height="24"
                                        Padding="0"
                                        Style="{StaticResource ToolBarButtonStyle}"
                                        ToolTip="マークを切り替え">
                                    <TextBlock x:Name="StarText"
                                               Text="★"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding MarkBrush}"/>
                                </Button>
                            </Grid>

                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ctrl:TreeLinesElement Grid.Column="0"
                                                       Segments="{Binding TreeLineSegments}"
                                                       CellWidth="16" VerticalAlignment="Stretch"/>
                                <Button Grid.Column="1"
                                        Content="{Binding ExpandGlyph}"
                                        Visibility="{Binding ToggleVisibility}"
                                        Command="{Binding ToggleExpandCommand}"
                                        Style="{StaticResource ExpandToggleStyle}"
                                        Foreground="#FF666666"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Grid x:Name="StatusIconGrid"
                                          Background="Transparent"
                                          VerticalAlignment="Center" Margin="2,0,4,0"
                                          Width="16" Height="16">
                                        <TextBlock x:Name="IconText"
                                                   Text="{Binding StatusIcon}"
                                                   Foreground="{Binding StatusBrush}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <!-- 完了タスク用：緑丸 + 白✔ -->
                                        <Border x:Name="CheckBadge"
                                                Background="#FF22AA44"
                                                CornerRadius="8"
                                                Width="16" Height="16"
                                                Visibility="Collapsed">
                                        <TextBlock Text="&#x2714;"
                                                       Foreground="White"
                                                       FontSize="8"
                                                       FontFamily="Segoe UI, sans-serif"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- 完了フォルダ用：緑四角背景 + 白フォルダ -->
                                        <Border x:Name="FolderBadge"
                                                Background="#FF22AA44"
                                                CornerRadius="3"
                                                Width="16" Height="16"
                                                Visibility="Collapsed">
                                            <TextBlock Text="&#xE8B7;"
                                                       Foreground="White"
                                                       FontSize="10"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock x:Name="NameLabel"
                                               Text="{Binding Name}"
                                               Foreground="{DynamicResource WindowFgBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolVis}}"/>
                                    <TextBox Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}"
                                             BorderThickness="1" Padding="1,0" MinWidth="80"
                                             VerticalAlignment="Center"
                                             IsVisibleChanged="OnNameEditorIsVisibleChanged"
                                             KeyDown="OnNameEditorKeyDown"
                                             LostFocus="OnNameEditorLostFocus"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Grid.Column="3" Text="{Binding DaysText}"
                                       Foreground="#FF666666" FontSize="10"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Padding="2,0"/>
                            <StackPanel Grid.Column="5" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="&#128221;"
                                        FontSize="11" Padding="1,0" Margin="0,0,1,0"
                                        BorderThickness="0" Background="Transparent"
                                        Foreground="{DynamicResource WindowFgBrush}" Cursor="Hand"
                                        Visibility="{Binding HasMemo, Converter={StaticResource BoolVis}}"
                                        Command="{Binding OpenMemoCommand}"
                                        ToolTip="&#12513;&#12514;&#12434;&#34920;&#31034;"/>
                                <Button Content="&#128279;"
                                        FontSize="11" Padding="1,0"
                                        BorderThickness="0" Background="Transparent"
                                        Foreground="{DynamicResource WindowFgBrush}" Cursor="Hand"
                                        Visibility="{Binding HasLink, Converter={StaticResource BoolVis}}"
                                        Command="{Binding OpenLinkCommand}"
                                        ToolTip="{Binding Item.Link}"/>
                            </StackPanel>
                        </Grid>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding Item, Converter={StaticResource ItemCompletedConverter}}" Value="True">
                            <Setter TargetName="IconText"   Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="CheckBadge" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsCompletedFolder}" Value="True">
                            <Setter TargetName="FolderBadge" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <!-- 黄色★のとき黒縁取り -->
                        <DataTrigger Binding="{Binding MarkLevel}" Value="1">
                            <Setter TargetName="StarText" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black"
                                                      ShadowDepth="0"
                                                      BlurRadius="2"
                                                      Opacity="1"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
