<Window x:Class="todochart.Views.TaskPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:todochart.ViewModels"
        Title="プロパティ"
        Width="480" Height="540"
        MinWidth="360" MinHeight="400"
        Background="#FFFFFFFF"
        Foreground="#FF000000"
        FontFamily="Meiryo UI, Segoe UI, sans-serif" FontSize="13"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FF3B3B3B"/>
            <Setter Property="Padding"    Value="0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#FFFFFFFF"/>
            <Setter Property="Foreground"   Value="#FF000000"/>
            <Setter Property="BorderBrush"  Value="#FFC8C8C8"/>
            <Setter Property="Padding"      Value="4,3"/>
            <Setter Property="CaretBrush"   Value="Black"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FF3B3B3B"/>
            <Setter Property="Margin"     Value="0,4"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFE8E8E8"/>
            <Setter Property="Foreground" Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
            <Setter Property="Padding"    Value="16,6"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background"  Value="#FFFFFFFF"/>
            <Setter Property="Foreground"  Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#FFF3F3F3"/>
            <Setter Property="Foreground"  Value="#FF3B3B3B"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
            <Setter Property="Padding"     Value="12,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 名前 -->
            <RowDefinition Height="*"/>     <!-- タブ -->
            <RowDefinition Height="Auto"/>  <!-- ボタン -->
        </Grid.RowDefinitions>

        <!-- ── 名前 ──────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <Label Content="名前"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13"/>
        </StackPanel>

        <!-- ── タブ ──────────────────────────────────────── -->
        <TabControl x:Name="MainTabControl" Grid.Row="1">

            <!-- 日程タブ（ToDo のみ） -->
            <TabItem x:Name="ScheduleTab" Header="日程">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- 完了チェック + WAIT -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,12"
                                    VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding Completed}"
                                      Content="完了済み"
                                      VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding IsWait}"
                                      Content="WAIT"
                                      Margin="12,0,0,0"
                                      VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 開始日 -->
                        <GroupBox Header="開始日" Foreground="#FF3B3B3B"
                                  BorderBrush="#FFC8C8C8" Margin="0,0,0,8">
                            <StackPanel Margin="6">
                                <CheckBox IsChecked="{Binding HasBeginDate}"
                                          Content="開始日を設定する"/>
                                <DatePicker SelectedDate="{Binding BeginDate}"
                                            IsEnabled="{Binding BeginDateEnabled}"
                                            Margin="0,4,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- 終了日 -->
                        <GroupBox Header="終了日" Foreground="#FF3B3B3B"
                                  BorderBrush="#FFC8C8C8" Margin="0,0,0,8">
                            <StackPanel Margin="6">
                                <CheckBox IsChecked="{Binding HasEndDate}"
                                          Content="終了日を設定する"/>
                                <DatePicker SelectedDate="{Binding EndDate}"
                                            IsEnabled="{Binding EndDateEnabled}"
                                            Margin="0,4,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- 日数カウント方法 -->
                        <GroupBox Header="日数カウント" Foreground="#FF3B3B3B"
                                  BorderBrush="#FFC8C8C8" Margin="0,0,0,8">
                            <StackPanel Margin="6">
                                <ComboBox SelectedIndex="{Binding DateCountLevel}">
                                    <ComboBoxItem Content="全日カウント"/>
                                    <ComboBoxItem Content="土日を除外"/>
                                    <ComboBoxItem Content="休日すべて除外"/>
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>

                        <!-- 期間表示 -->
                        <TextBlock Text="{Binding DaysLabel}"
                                   Foreground="#FF0078D7"
                                   Margin="0,4"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- メモタブ -->
            <TabItem x:Name="MemoTab" Header="メモ">
                <TextBox Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="4"/>
            </TabItem>

            <!-- リンクタブ -->
            <TabItem x:Name="LinkTab" Header="リンク">
                <StackPanel Margin="8">
                    <Label Content="ファイル / フォルダ / URL"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Link, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="📂" Margin="4,0,0,0"
                                Click="OnBrowseFileClick" ToolTip="ファイルを参照"/>
                        <Button Grid.Column="2" Content="🌐" Margin="4,0,0,0"
                                Click="OnOpenLinkClick"   ToolTip="リンクを開く"/>
                    </Grid>
                    <Button Content="リンクをクリア" Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Click="OnClearLinkClick"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- ── OK / キャンセル ─────────────────────────────── -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    IsDefault="True"
                    MinWidth="80"
                    Click="OnOkClick"/>
            <Button Content="キャンセル"
                    IsCancel="True"
                    MinWidth="80"
                    Margin="8,0,0,0"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
