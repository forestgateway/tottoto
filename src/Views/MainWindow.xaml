<Window x:Class="todochart.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:todochart.ViewModels"
        xmlns:local="clr-namespace:todochart.Views"
        xmlns:ctrl="clr-namespace:todochart.Controls"
        xmlns:conv="clr-namespace:todochart.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1300" Height="720"
        MinWidth="800" MinHeight="480"
        Icon="/snowflake.ico"
        Background="{StaticResource WindowBgBrush}"
        Foreground="{StaticResource WindowFgBrush}"
        FontFamily="Meiryo UI, Segoe UI, sans-serif" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolVis"/>
        <conv:IsEqualConverter x:Key="IsEqual"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="T"      Modifiers="Ctrl"       Command="{Binding NewToDoCommand}"/>
        <KeyBinding Key="N"      Modifiers="Ctrl"       Command="{Binding NewFolderCommand}"/>
        <KeyBinding Key="Delete"                        Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="Return"                        Command="{Binding EditCommand}"/>
        <KeyBinding Key="F2"                            Command="{Binding BeginRenameCommand}"/>
        <KeyBinding Key="Space"                         Command="{Binding ToggleCompleteCommand}"/>
        <KeyBinding Key="C"      Modifiers="Ctrl"       Command="{Binding CopyItemCommand}"/>
        <KeyBinding Key="X"      Modifiers="Ctrl"       Command="{Binding CutItemCommand}"/>
        <KeyBinding Key="V"      Modifiers="Ctrl"       Command="{Binding PasteItemCommand}"/>
        <KeyBinding Key="Right"  Modifiers="Alt"        Command="{Binding ChartNextCommand}"/>
        <KeyBinding Key="Left"   Modifiers="Alt"        Command="{Binding ChartPrevCommand}"/>
        <KeyBinding Key="Right"  Modifiers="Alt+Shift"  Command="{Binding ChartNext7Command}"/>
        <KeyBinding Key="Left"   Modifiers="Alt+Shift"  Command="{Binding ChartPrev7Command}"/>
        <KeyBinding Key="Home"   Modifiers="Alt"        Command="{Binding ChartTodayCommand}"/>
        <KeyBinding Key="Right"  Modifiers="Shift"      Command="{Binding ShiftBeginPlusCommand}"/>
        <KeyBinding Key="Left"   Modifiers="Shift"      Command="{Binding ShiftBeginMinusCommand}"/>
        <KeyBinding Key="Right"  Modifiers="Ctrl"       Command="{Binding ShiftEndPlusCommand}"/>
        <KeyBinding Key="Left"   Modifiers="Ctrl"       Command="{Binding ShiftEndMinusCommand}"/>
        <KeyBinding Key="Up"     Modifiers="Ctrl"       Command="{Binding MoveUpCommand}"/>
        <KeyBinding Key="Down"   Modifiers="Ctrl"       Command="{Binding MoveDownCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- メニュー -->
            <RowDefinition Height="Auto"/>  <!-- ツールバー -->
            <RowDefinition Height="Auto"/>  <!-- スケジュールタブバー -->
            <RowDefinition Height="*"/>     <!-- コンテンツ -->
            <RowDefinition Height="Auto"/>  <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- ══ メニューバー ══════════════════════════════════════ -->
        <Menu Grid.Row="0" Background="{StaticResource PanelBgBrush}" Foreground="{StaticResource WindowFgBrush}">
            <MenuItem Header="ファイル(_F)" Foreground="{StaticResource WindowFgBrush}">
                <MenuItem Header="新規作成(タスクリスト)(_N)" Command="{Binding NewCommand}"/>
                <MenuItem Header="新規作成(Issue Tracking)(_I)" Command="{Binding NewIssueTrackingCommand}"/>
                <MenuItem Header="開く(_O)..."       Command="{Binding OpenCommand}"   InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="上書き保存(_S)"    Command="{Binding SaveCommand}"   InputGestureText="Ctrl+S"/>
                <MenuItem Header="名前を付けて保存(_A)..." Command="{Binding SaveAsCommand}"/>
                <Separator/>
                <MenuItem Header="このスケジュールを閉じる(_W)" Command="{Binding CloseScheduleCommand}"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="編集(_E)" Foreground="{StaticResource WindowFgBrush}">
                <MenuItem Header="フォルダの新規作成(_F)" Command="{Binding NewFolderCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="タスクの新規作成(_T)"   Command="{Binding NewToDoCommand}"   InputGestureText="Ctrl+T"/>
                <Separator/>
                <MenuItem Header="コピー(_C)"     Command="{Binding CopyItemCommand}"  InputGestureText="Ctrl+C"/>
                <MenuItem Header="切り取り(_X)"   Command="{Binding CutItemCommand}"   InputGestureText="Ctrl+X"/>
                <MenuItem Header="貼り付け(_V)"   Command="{Binding PasteItemCommand}" InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="プロパティ(_P)" Command="{Binding EditCommand}"         InputGestureText="Enter"/>
                <MenuItem Header="完了切替(_R)"   Command="{Binding ToggleCompleteCommand}" InputGestureText="Space"/>
                <Separator/>
                <MenuItem Header="削除(_D)" Command="{Binding DeleteCommand}" InputGestureText="Delete"/>
                <Separator/>
                <MenuItem Header="上へ移動(_U)" Command="{Binding MoveUpCommand}"   InputGestureText="Ctrl+↑"/>
                <MenuItem Header="下へ移動(_D)" Command="{Binding MoveDownCommand}" InputGestureText="Ctrl+↓"/>
                <Separator/>
                <MenuItem Header="アーカイブ(_A)" Command="{Binding ArchiveCommand}"/>
                <MenuItem Header="アーカイブ一覧(_V)..." Command="{Binding ShowArchiveListCommand}"/>
                <Separator/>
                <MenuItem Header="Issue Tracking 設定編集(_G)..." Command="{Binding EditIssueTrackingCommand}"/>
            </MenuItem>
            <MenuItem Header="チャート(_C)" Foreground="{StaticResource WindowFgBrush}">
                <MenuItem Header="1日進む"     Command="{Binding ChartNextCommand}"  InputGestureText="Alt+→"/>
                <MenuItem Header="1日戻る"     Command="{Binding ChartPrevCommand}"  InputGestureText="Alt+←"/>
                <MenuItem Header="7日進む"     Command="{Binding ChartNext7Command}" InputGestureText="Alt+Shift+→"/>
                <MenuItem Header="7日戻る"     Command="{Binding ChartPrev7Command}" InputGestureText="Alt+Shift+←"/>
                <MenuItem Header="今日を表示"  Command="{Binding ChartTodayCommand}" InputGestureText="Alt+Home"/>
                <Separator/>
                <MenuItem Header="開始日を⊕1日" Command="{Binding ShiftBeginPlusCommand}"  InputGestureText="Shift+→"/>
                <MenuItem Header="開始日を⊖1日" Command="{Binding ShiftBeginMinusCommand}" InputGestureText="Shift+←"/>
                <MenuItem Header="終了日を⊕1日" Command="{Binding ShiftEndPlusCommand}"    InputGestureText="Ctrl+→"/>
                <MenuItem Header="終了日を⊖1日" Command="{Binding ShiftEndMinusCommand}"   InputGestureText="Ctrl+←"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)" Foreground="{StaticResource WindowFgBrush}">
                <MenuItem Header="バージョン情報(_A)..." Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- ══ ツールバー ═══════════════════════════════════════ -->
        <ToolBar Grid.Row="1"
                 Background="{StaticResource PanelBgBrush}"
                 Foreground="{StaticResource SubTextBrush}"
                 ToolBarTray.IsLocked="True">
            <!-- ファイル操作 -->
            <Button Content="📄 新規"         Command="{Binding NewCommand}"     Style="{StaticResource ToolBarButtonStyle}" ToolTip="タスクリストを新規作成"/>
            <Button Content="🔗 新規(Issue)"  Command="{Binding NewIssueTrackingCommand}" Style="{StaticResource ToolBarButtonStyle}" ToolTip="Issue Tracking を新規作成"/>
            <Button Content="📂 開く"         Command="{Binding OpenCommand}"    Style="{StaticResource ToolBarButtonStyle}" ToolTip="ファイルを開く"/>
            <Button Content="💾 保存"         Command="{Binding SaveCommand}"    Style="{StaticResource ToolBarButtonStyle}" ToolTip="上書き保存"/>
            <Separator/>
            <!-- Issue 更新ボタン (アクティブタブが Issue Tracking のときのみ有効) -->
            <Button Content="🔄 Update"
                    Command="{Binding UpdateIssueTrackingCommand}"
                    Style="{StaticResource ToolBarButtonStyle}"
                    ToolTip="Issue 一覧を最新に更新する"
                    Visibility="{Binding ActiveEntry.IsIssueTracking, Converter={StaticResource BoolVis}}"/>
            <Separator/>
            <!-- アイテム操作 -->
            <Button Content="📁＋ フォルダ"   Command="{Binding NewFolderCommand}" Style="{StaticResource ToolBarButtonStyle}" ToolTip="フォルダを追加"/>
            <Button Content="☐＋ タスク"      Command="{Binding NewToDoCommand}"   Style="{StaticResource ToolBarButtonStyle}" ToolTip="タスクを追加"/>
            <Button Content="✏ 編集"          Command="{Binding EditCommand}"      Style="{StaticResource ToolBarButtonStyle}" ToolTip="プロパティを編集"/>
            <Button Content="🗑 削除"          Command="{Binding DeleteCommand}"    Style="{StaticResource ToolBarButtonStyle}" ToolTip="削除"/>
            <Separator/>
            <!-- 順序 -->
            <Button Content="↑"  Command="{Binding MoveUpCommand}"   Style="{StaticResource ToolBarButtonStyle}" ToolTip="上へ移動"/>
            <Button Content="↓"  Command="{Binding MoveDownCommand}" Style="{StaticResource ToolBarButtonStyle}" ToolTip="下へ移動"/>
            <Separator/>
            <!-- チャート移動 -->
            <Button Content="◀◀" Command="{Binding ChartPrev7Command}" Style="{StaticResource ToolBarButtonStyle}" ToolTip="7日前"/>
            <Button Content="◀"  Command="{Binding ChartPrevCommand}"  Style="{StaticResource ToolBarButtonStyle}" ToolTip="1日前"/>
            <Button Content="今日" Command="{Binding ChartTodayCommand}" Style="{StaticResource ToolBarButtonStyle}" ToolTip="今日を中心に表示"/>
            <Button Content="▶"  Command="{Binding ChartNextCommand}"  Style="{StaticResource ToolBarButtonStyle}" ToolTip="1日後"/>
            <Button Content="▶▶" Command="{Binding ChartNext7Command}" Style="{StaticResource ToolBarButtonStyle}" ToolTip="7日後"/>
            <Separator/>
            <!-- 日付シフト -->
            <Button Content="⬅開始" Command="{Binding ShiftBeginMinusCommand}" Style="{StaticResource ToolBarButtonStyle}" ToolTip="開始日を1日前へ"/>
            <Button Content="開始➡" Command="{Binding ShiftBeginPlusCommand}"  Style="{StaticResource ToolBarButtonStyle}" ToolTip="開始日を1日後へ"/>
            <Button Content="⬅終了" Command="{Binding ShiftEndMinusCommand}"   Style="{StaticResource ToolBarButtonStyle}" ToolTip="終了日を1日前へ"/>
            <Button Content="終了➡" Command="{Binding ShiftEndPlusCommand}"    Style="{StaticResource ToolBarButtonStyle}" ToolTip="終了日を1日後へ"/>
            <Separator/>
            <!-- 完了タスク非表示 -->
            <ToggleButton Content="☑ 完了を隠す"
                          IsChecked="{Binding HideCompleted, Mode=TwoWay}"
                          Style="{StaticResource ToolBarToggleButtonStyle}"
                          ToolTip="完了済みタスクを一覧から隠す"/>
            <Separator/>
            <Button Content="📅 今日の予定"
                    Command="{Binding ShowTodayScheduleCommand}"
                    Style="{StaticResource ToolBarButtonStyle}"
                    ToolTip="今日の日付が含まれるタスクを別ウィンドウで表示"/>
        </ToolBar>

        <!-- ══ スケジュールタブバー ══════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- 左右移動ボタン -->
                <Button DockPanel.Dock="Right"
                        Content="▶"
                        Command="{Binding MoveScheduleRightCommand}"
                        Style="{StaticResource ToolBarButtonStyle}"
                        ToolTip="スケジュールを右へ移動"
                        Padding="4,2"/>
                <Button DockPanel.Dock="Right"
                        Content="◀"
                        Command="{Binding MoveScheduleLeftCommand}"
                        Style="{StaticResource ToolBarButtonStyle}"
                        ToolTip="スケジュールを左へ移動"
                        Padding="4,2"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Schedules}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ScheduleEntry}">
                                <Border x:Name="TabBorder"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1,1,1,0"
                                        Margin="2,3,0,0"
                                        Padding="8,3"
                                        Cursor="Hand"
                                        Background="{StaticResource WindowBgBrush}"
                                        AllowDrop="True"
                                        MouseLeftButtonDown="OnScheduleTabClick"
                                        PreviewMouseMove="OnScheduleTabPreviewMouseMove"
                                        DragOver="OnScheduleTabDragOver"
                                        DragLeave="OnScheduleTabDragLeave"
                                        Drop="OnScheduleTabDrop">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="タブを閉じる(_W)"
                                                      Click="OnScheduleTabClose"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <TextBlock Text="{Binding TabTitle}"
                                               FontSize="13"
                                               Foreground="{StaticResource WindowFgBrush}"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsEqual}">
                                                <Binding Path="DataContext.ActiveEntry" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                <Binding/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                                        <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,2,1,0"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══ コンテンツ（タスクリスト ＋ ガントチャート） ═══════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440" MinWidth="200" x:Name="LeftColDef"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- ┌── 左ペイン（タスクリスト） ───────────────────┐ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 列ヘッダー -->
                    <RowDefinition Height="*"/>     <!-- アイテムリスト -->
                </Grid.RowDefinitions>

                <!-- 列ヘッダー -->
                <Border Grid.Row="0" Height="{StaticResource HeaderHeight}" Background="{StaticResource HeaderBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid x:Name="TaskHeaderGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ColMark"   Width="36" MinWidth="28"/>
                            <ColumnDefinition x:Name="ColName"   Width="*"  MinWidth="100"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition x:Name="ColStatus" Width="80" MinWidth="40"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition x:Name="ColML"     Width="36" MinWidth="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="タスク名" Style="{StaticResource ColumnHeaderStyle}"/>
                        <TextBlock Grid.Column="0" Text="★" Style="{StaticResource ColumnHeaderStyle}" HorizontalAlignment="Center"/>
                        <GridSplitter Grid.Column="2"
                                      Width="4"
                                      HorizontalAlignment="Stretch"
                                      Background="Transparent"
                                      Cursor="SizeWE"
                                      ResizeBehavior="PreviousAndNext"
                                      ResizeDirection="Columns"/>
                        <TextBlock Grid.Column="3" Text="状態"    Style="{StaticResource ColumnHeaderStyle}"/>
                        <GridSplitter Grid.Column="4"
                                      Width="4"
                                      HorizontalAlignment="Stretch"
                                      Background="Transparent"
                                      Cursor="SizeWE"
                                      ResizeBehavior="PreviousAndNext"
                                      ResizeDirection="Columns"/>
                        <TextBlock Grid.Column="5" Text="ML"      Style="{StaticResource ColumnHeaderStyle}"/>
                    </Grid>
                </Border>

                <!-- タスクリスト本体 -->
                <ListBox x:Name="TaskListBox"
                         Grid.Row="1"
                         ItemsSource="{Binding FlatItems}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         Background="{StaticResource WindowBgBrush}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         ItemContainerStyle="{StaticResource TaskRowContainerStyle}"
                         MouseDoubleClick="OnListBoxMouseDoubleClick"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="OnTaskListPreviewMouseDown"
                         PreviewMouseMove="OnTaskListPreviewMouseMove"
                         DragOver="OnTaskListDragOver"
                         DragLeave="OnTaskListDragLeave"
                         Drop="OnTaskListDrop"
                         PreviewKeyDown="OnTaskListPreviewKeyDown">
                    <ListBox.InputBindings>
                        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding CopyItemCommand}"/>
                        <KeyBinding Key="X" Modifiers="Ctrl" Command="{Binding CutItemCommand}"/>
                        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding PasteItemCommand}"/>
                    </ListBox.InputBindings>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{Binding ContextCompleteHeader}"
                                      Command="{Binding ToggleCompleteCommand}"
                                      IsEnabled="{Binding IsContextCompleteEnabled}"/>
                            <MenuItem Header="{Binding ContextWaitHeader}"
                                      Command="{Binding ToggleWaitCommand}"
                                      IsEnabled="{Binding IsContextWaitEnabled}"/>
                            <Separator/>
                            <MenuItem Header="新規タスク(_T)"
                                      Command="{Binding NewToDoCommand}"/>
                            <MenuItem Header="新規フォルダ(_F)"
                                      Command="{Binding NewFolderCommand}"/>
                            <Separator/>
                            <MenuItem Header="コピー(_C)"     Command="{Binding CopyItemCommand}"  InputGestureText="Ctrl+C"/>
                            <MenuItem Header="切り取り(_X)"   Command="{Binding CutItemCommand}"   InputGestureText="Ctrl+X"/>
                            <MenuItem Header="貼り付け(_V)"   Command="{Binding PasteItemCommand}" InputGestureText="Ctrl+V"/>
                            <Separator/>
                            <MenuItem Header="削除(_D)"
                                      Command="{Binding DeleteCommand}"/>
                            <Separator/>
                            <MenuItem Header="アーカイブ(_A)"
                                      Command="{Binding ArchiveCommand}"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TaskRowViewModel}">
                            <Border Background="{Binding RowBackground}"
                                    BorderBrush="#15000000" BorderThickness="0,0,0,1">
                                <Grid>
                                    <!-- 選択色オーバーレイ (ヒットテスト無効にして下の操作を妨げない) -->
                                    <Border Background="{StaticResource RowSelectedBrush}"
                                            BorderBrush="#FFADD6FF"
                                            BorderThickness="0,1,0,1"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}"
                                            IsHitTestVisible="False"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding ElementName=ColMark,   Path=Width}"/>
                                            <ColumnDefinition Width="{Binding ElementName=ColName,   Path=Width}"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="{Binding ElementName=ColStatus, Path=Width}"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="{Binding ElementName=ColML,     Path=Width}"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- マーク列 -->
                                        <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Command="{Binding ToggleMarkCommand}"
                                                    Width="24" Height="24"
                                                    Padding="0"
                                                    Style="{StaticResource ToolBarButtonStyle}"
                                                    ToolTip="マークを切り替え">
                                                <TextBlock x:Name="StarText"
                                                           Text="★"
                                                           FontSize="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding MarkBrush}"/>
                                            </Button>
                                        </Grid>

                                        <!-- タスク名（罫線 ＋ 展開ボタン ＋ アイコン ＋ テキスト） -->
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>  <!-- tree lines -->
                                                <ColumnDefinition Width="16"/>    <!-- toggle -->
                                                <ColumnDefinition Width="*"/>     <!-- icon + name -->
                                            </Grid.ColumnDefinitions>

                                            <!-- ツリー罫線 -->
                                            <ctrl:TreeLinesElement Grid.Column="0"
                                                                   Segments="{Binding TreeLineSegments}"
                                                                   CellWidth="16"
                                                                   VerticalAlignment="Stretch"/>

                                            <Button Grid.Column="1"
                                                    Content="{Binding ExpandGlyph}"
                                                    Visibility="{Binding ToggleVisibility}"
                                                    Command="{Binding ToggleExpandCommand}"
                                                    Style="{StaticResource ExpandToggleStyle}"
                                                    Foreground="#FF666666"/>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <!-- ステータスアイコン -->
                                                <Grid x:Name="StatusIconGrid"
                                                      Background="Transparent"
                                                      VerticalAlignment="Center" Margin="2,0,4,0"
                                                      Width="16" Height="16">
                                                    <TextBlock x:Name="IconText"
                                                               Text="{Binding StatusIcon}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    <!-- 完了タスク用：緑丸 + 白✔ -->
                                                    <Border x:Name="CheckBadge"
                                                            Background="#FF22AA44"
                                                            CornerRadius="8"
                                                            Width="16" Height="16"
                                                            Visibility="Collapsed">
                                                        <TextBlock Text="&#x2714;"
                                                                   Foreground="White"
                                                                   FontSize="8"
                                                                   FontFamily="Segoe UI, sans-serif"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <!-- 完了フォルダ用：緑四角背景 + 白フォルダ -->
                                                    <Border x:Name="FolderBadge"
                                                            Background="#FF22AA44"
                                                            CornerRadius="3"
                                                            Width="16" Height="16"
                                                            Visibility="Collapsed">
                                                        <TextBlock Text="&#xE8B7;"
                                                                   Foreground="White"
                                                                   FontSize="10"
                                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                                <TextBlock x:Name="NameLabel"
                                                           Text="{Binding Name}"
                                                           Foreground="{StaticResource WindowFgBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolVis}}"/>
                                                <TextBox x:Name="NameEditor"
                                                         Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}"
                                                         BorderThickness="1"
                                                         Padding="1,0"
                                                         MinWidth="80"
                                                         VerticalAlignment="Center"
                                                         IsVisibleChanged="OnNameEditorIsVisibleChanged"
                                                         KeyDown="OnNameEditorKeyDown"
                                                         LostFocus="OnNameEditorLostFocus"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 状態 -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DaysText}"
                                                   Foreground="{StaticResource SubTextBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Padding="2,0"/>
                                        <!-- メモ / リンク アイコン -->
                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Content="📝"
                                                    FontSize="12"
                                                    Padding="1,0"
                                                    Margin="0,0,1,0"
                                                    BorderThickness="0"
                                                    Background="Transparent"
                                                    Cursor="Hand"
                                                    Visibility="{Binding HasMemo, Converter={StaticResource BoolVis}}"
                                                    Command="{Binding OpenMemoCommand}"
                                                    ToolTip="メモを表示"/>
                                            <Button Content="🔗"
                                                    FontSize="12"
                                                    Padding="1,0"
                                                    BorderThickness="0"
                                                    Background="Transparent"
                                                    Cursor="Hand"
                                                    Visibility="{Binding HasLink, Converter={StaticResource BoolVis}}"
                                                    Command="{Binding OpenLinkCommand}"
                                                    ToolTip="{Binding Item.Link}"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Item.Completed}" Value="True">
                                    <Setter TargetName="IconText"   Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="CheckBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCompletedFolder}" Value="True">
                                    <Setter TargetName="FolderBadge" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- 黄色★のとき黒縁取り -->
                                <DataTrigger Binding="{Binding MarkLevel}" Value="1">
                                    <Setter TargetName="StarText" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="Black"
                                                              ShadowDepth="0"
                                                              BlurRadius="2"
                                                              Opacity="1"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- ── スプリッター ─────────────────────────────── -->
            <GridSplitter Grid.Column="1"
                          Width="1"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          Cursor="SizeWE"/>

            <!-- ┌── 右ペイン（ガントチャート） ─────────────────┐ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- チャートヘッダー -->
                    <RowDefinition Height="*"/>    <!-- チャート本体 -->
                </Grid.RowDefinitions>

                <!-- チャートヘッダー（日付ラベル） -->
                <ScrollViewer x:Name="ChartHeaderScroll"
                              Grid.Row="0"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Background="{StaticResource HeaderBgBrush}"
                              Visibility="{Binding IsChartReady, Converter={StaticResource BoolVis}}">
                    <ctrl:GanttHeaderElement x:Name="GanttHeader"
                                             Days="{Binding ChartDays}"
                                             CellWidth="{StaticResource CellWidth}"
                                             Height="{StaticResource HeaderHeight}"/>
                </ScrollViewer>

                <!-- チャート本体 + 読み込み中オーバーレイ -->
                <Grid Grid.Row="1" ClipToBounds="True">
                    <!-- チャート本体（ガントバー行） -->
                    <ScrollViewer x:Name="ChartBodyScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden"
                                  Background="{StaticResource ChartBgBrush}"
                                  ScrollChanged="OnChartBodyScrollChanged"
                                  PreviewMouseLeftButtonDown="OnChartMouseLeftButtonDown"
                                  PreviewMouseMove="OnChartMouseMove"
                                  PreviewMouseLeftButtonUp="OnChartMouseLeftButtonUp"
                                  MouseLeave="OnChartMouseLeave"
                                  MouseRightButtonUp="OnChartMouseRightButtonUp"
                                  Visibility="{Binding IsChartReady, Converter={StaticResource BoolVis}}">
                        <ItemsControl x:Name="ChartRowsControl"
                                      ItemsSource="{Binding FlatItems}"
                                      VirtualizingPanel.IsVirtualizing="False"
                                      SizeChanged="OnChartRowsControlSizeChanged">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TaskRowViewModel}">
                                    <Grid Height="{StaticResource RowHeight}">
                                        <ctrl:GanttRowElement Cells="{Binding ChartCells}"
                                                              CellWidth="{StaticResource CellWidth}"
                                                              Height="{StaticResource RowHeight}"
                                                              IsSelected="{Binding IsSelected}"
                                                              CalloutTexts="{Binding CalloutTexts}"
                                                              HoveredColumnIndex="{Binding DataContext.HoveredColumnIndex, ElementName=ChartRowsControl}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 吹き出しオーバーレイ（全行・クリップなし） -->
                    <ctrl:CalloutOverlayControl x:Name="ChartCalloutOverlay"
                                               DataContext="{Binding}"
                                               IsHitTestVisible="True"
                                               ClipToBounds="False"
                                               VerticalAlignment="Stretch"
                                               HorizontalAlignment="Stretch"
                                               Visibility="{Binding IsChartReady, Converter={StaticResource BoolVis}}"
                                               Panel.ZIndex="10"/>

                    <!-- 読み込み中オーバーレイ -->
                    <Border Background="{StaticResource ChartBgBrush}"
                            Visibility="{Binding IsChartReady, Converter={StaticResource InverseBoolVis}}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="⏳"
                                       FontSize="32"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="チャート読み込み中..."
                                       FontSize="13"
                                       Foreground="{StaticResource SubTextBrush}"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══ ステータスバー ════════════════════════════════════ -->
        <StatusBar Grid.Row="4" Background="{StaticResource PanelBgBrush}" Foreground="{StaticResource SubTextBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TodayLabel"
                           FontSize="12"
                           Foreground="{StaticResource AccentBrush}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
