<Window x:Class="todochart.Views.HolidaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:todochart.ViewModels"
        xmlns:conv="clr-namespace:todochart.Converters"
        Title="休日設定"
        Width="700" Height="620"
        MinHeight="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFFFF"
        Foreground="#FF000000"
        FontFamily="Meiryo UI, Segoe UI, sans-serif" FontSize="13"
        ShowInTaskbar="False">

    <Window.Resources>
        <conv:DateOnlyToDateTimeConverter x:Key="DateOnlyToDateTimeConverter"/>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FF3B3B3B"/>
            <Setter Property="Padding"    Value="0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#FFFFFFFF"/>
            <Setter Property="Foreground"   Value="#FF000000"/>
            <Setter Property="BorderBrush"  Value="#FFC8C8C8"/>
            <Setter Property="Padding"      Value="4,3"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FF3B3B3B"/>
            <Setter Property="Margin"     Value="0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#FFFFFFFF"/>
            <Setter Property="Foreground"  Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#FFE8E8E8"/>
            <Setter Property="Foreground"  Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
            <Setter Property="Padding"     Value="16,6"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE0E0E0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#FFE0E0E0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- タイトル -->
            <RowDefinition Height="*"/>     <!-- 左右区画 -->
            <RowDefinition Height="Auto"/>  <!-- ステータス -->
            <RowDefinition Height="Auto"/>  <!-- OK/キャンセル -->
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="休日設定"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#FF3B3B3B"
                   Margin="0,0,0,12"/>

        <!-- 左右区画 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側区画 -->
            <StackPanel Grid.Column="0">
                <GroupBox Header="曜日別の休日レベル設定" Padding="8" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="日:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding SundayLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="月:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding MondayLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="火:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding TuesdayLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="水:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding WednesdayLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="木:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding ThursdayLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="金:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding FridayLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="土:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding SaturdayLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <Button Content="内閣府から祝日データを取得"
                        Click="OnFetchJapanHolidaysClick"
                        HorizontalAlignment="Left"
                        Padding="12,6"
                        Margin="0,0,0,12"/>

                <GroupBox Header="新しい休日を追加" Padding="8" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="日付:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker Grid.Column="1" SelectedDate="{Binding NewDate, Converter={StaticResource DateOnlyToDateTimeConverter}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="休日レベル:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding NewLevel}">
                                <ComboBoxItem Content="平日"/>
                                <ComboBoxItem Content="半休日(土曜など)"/>
                                <ComboBoxItem Content="全休日(日・祝など)"/>
                            </ComboBox>
                        </Grid>

                        <Button Content="追加" Command="{Binding AddHolidayCommand}" HorizontalAlignment="Left" Padding="12,4"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- 右側区画 -->
            <GroupBox Grid.Column="2" Header="休日・特別日リスト" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding SpecialHolidays}"
                              SelectedItem="{Binding SelectedHoliday}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日付" Binding="{Binding Date, StringFormat=yyyy/MM/dd}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="レベル" Binding="{Binding LevelLabel}" Width="150" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="1"
                            Content="選択した休日を削除"
                            Command="{Binding RemoveHolidayCommand}"
                            HorizontalAlignment="Left"
                            Padding="12,4"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ステータスメッセージ -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#FF0066CC"
                   FontSize="11"
                   Margin="0,10,0,12"/>

        <!-- OK/キャンセル -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Click="OnOkClick" Padding="24,6" Margin="0,0,8,0"/>
            <Button Content="キャンセル" IsCancel="True" Padding="24,6"/>
        </StackPanel>
    </Grid>
</Window>
