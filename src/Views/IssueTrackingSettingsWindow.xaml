<Window x:Class="todochart.Views.IssueTrackingSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:todochart.ViewModels"
        xmlns:conv="clr-namespace:todochart.Converters"
        Title="Issue Tracking Settings"
        Width="520" Height="570"
        MinHeight="450"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFFFF"
        Foreground="#FF000000"
        FontFamily="Meiryo UI, Segoe UI, sans-serif" FontSize="13"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:NullableBoolToTestColorConverter x:Key="BoolToTestColor"/>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FF3B3B3B"/>
            <Setter Property="Padding"    Value="0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#FFFFFFFF"/>
            <Setter Property="Foreground"   Value="#FF000000"/>
            <Setter Property="BorderBrush"  Value="#FFC8C8C8"/>
            <Setter Property="Padding"      Value="4,3"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FF3B3B3B"/>
            <Setter Property="Margin"     Value="0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#FFFFFFFF"/>
            <Setter Property="Foreground"  Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background"  Value="#FFFFFFFF"/>
            <Setter Property="Foreground"  Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
            <Setter Property="Padding"     Value="4,3"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#FFE8E8E8"/>
            <Setter Property="Foreground"  Value="#FF000000"/>
            <Setter Property="BorderBrush" Value="#FFC8C8C8"/>
            <Setter Property="Padding"     Value="16,6"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- タイトル -->
            <RowDefinition Height="Auto"/>  <!-- 入力フォーム -->
            <RowDefinition Height="Auto"/>  <!-- 接続テスト行 -->
            <RowDefinition Height="*"/>     <!-- ログエリア -->
            <RowDefinition Height="Auto"/>  <!-- OK/キャンセル -->
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="Issue Tracking 接続設定"
                   FontSize="14" FontWeight="Bold"
                   Foreground="#FF3B3B3B"
                   Margin="0,0,0,12"/>

        <!-- 入力フォーム -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: Provider -->
                <RowDefinition Height="Auto"/>  <!-- 1: DisplayName -->
                <RowDefinition Height="Auto"/>  <!-- 2: BaseUrl -->
                <RowDefinition Height="Auto"/>  <!-- 3: ProjectId -->
                <RowDefinition Height="Auto"/>  <!-- 4: ApiToken (ラベルはプロバイダーで切替) -->
                <RowDefinition Height="Auto"/>  <!-- 5: Email (Jira Cloud のみ) -->
                <RowDefinition Height="Auto"/>  <!-- 6: Username (JiraOnPrem のみ) -->
                <RowDefinition Height="Auto"/>  <!-- 7: Query -->
                <RowDefinition Height="Auto"/>  <!-- 8: ExtraParams (JiraOnPrem のみ) -->
                <RowDefinition Height="Auto"/>  <!-- 9: MaxResults (Jira / JiraOnPrem) -->
                <RowDefinition Height="Auto"/>  <!-- 10: AutoRefresh -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Provider -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <Run Text="プロバイダー:"/>
            </TextBlock>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding Providers}"
                      SelectedItem="{Binding Provider, Mode=TwoWay}"
                      Margin="0,0,0,8"/>

            <!-- DisplayName -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <Run Text="表示名:"/>
            </TextBlock>
            <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <!-- BaseUrl (必須) -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <Run Foreground="#FFCC0000" Text="* "/>
                <Run Text="ベース URL:"/>
            </TextBlock>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"
                     ToolTip="例: https://gitlab.example.com  /  https://yoursite.atlassian.net  /  https://jira.example.com  /  https://redmine.example.com"/>

            <!-- ProjectId (必須) -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <Run Foreground="#FFCC0000" Text="* "/>
                <Run Text="プロジェクト ID:"/>
            </TextBlock>
            <TextBox Grid.Row="3" Grid.Column="1"
                     Text="{Binding ProjectId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"
                     ToolTip="GitLab: 数値 ID または namespace/project  /  Jira Cloud / JiraOnPrem: プロジェクトキー (例: DTOFSOFT70)  /  Redmine: プロジェクト識別子 (例: myproject)"/>

            <!-- ApiToken (必須) ― ラベルをプロバイダーで切替 -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <Run Foreground="#FFCC0000" Text="* "/>
                <Run>
                    <Run.Style>
                        <Style TargetType="Run">
                            <Setter Property="Text" Value="API トークン:"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                    <Setter Property="Text" Value="Password / API Token:"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Run.Style>
                </Run>
            </TextBlock>
            <PasswordBox x:Name="ApiTokenBox"
                         Grid.Row="4" Grid.Column="1"
                         Margin="0,0,0,8">
                <PasswordBox.ToolTip>
                    <TextBlock>
                        <Run Text="GitLab: Personal Access Token"/>
                        <LineBreak/>
                        <Run Text="Jira Cloud: API トークン"/>
                        <LineBreak/>
                        <Run Text="JiraOnPrem: パスワードまたは API トークン"/>
                        <LineBreak/>
                        <Run Text="Redmine: API Access Key"/>
                    </TextBlock>
                </PasswordBox.ToolTip>
            </PasswordBox>

            <!-- Email (Jira Cloud のみ必須・表示) -->
            <TextBlock Grid.Row="5" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="Jira">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Foreground="#FFCC0000" Text="* "/>
                <Run Text="メールアドレス:"/>
            </TextBlock>
            <TextBox x:Name="EmailBox"
                     Grid.Row="5" Grid.Column="1"
                     Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"
                     ToolTip="Jira Cloud Basic 認証用のメールアドレス">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="Jira">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Username (JiraOnPrem のみ必須・表示) -->
            <TextBlock Grid.Row="6" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Foreground="#FFCC0000" Text="* "/>
                <Run Text="Username:"/>
            </TextBlock>
            <TextBox x:Name="UsernameBox"
                     Grid.Row="6" Grid.Column="1"
                     Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"
                     ToolTip="JiraOnPrem Basic 認証用ユーザー名 (例: user@example.com)">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Query (GitLab / Jira Cloud / JiraOnPrem いずれも任意) -->
            <TextBlock Grid.Row="7" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <!-- ラベルテキスト: GitLab/Jira Cloud → クエリ条件 / JiraOnPrem → Custom Query (JQL) -->
                <Run>
                    <Run.Style>
                        <Style TargetType="Run">
                            <Setter Property="Text" Value="クエリ条件:"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                    <Setter Property="Text" Value="Custom Query (JQL):"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Run.Style>
                </Run>
            </TextBlock>
            <TextBox Grid.Row="7" Grid.Column="1"
                     Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8">
                <TextBox.ToolTip>
                    <TextBlock>
                        <Run Text="GitLab: assignee_username=me&amp;state=opened"/>
                        <LineBreak/>
                        <Run Text="Jira Cloud: JQL (例: project = MYPROJ AND assignee = currentUser())"/>
                        <LineBreak/>
                        <Run Text="JiraOnPrem: 追加 JQL 条件 (例: assignee=currentUser() AND statusCategory!=Done)"/>
                        <LineBreak/>
                        <Run Text="Redmine: URL クエリ追加条件 (例: status_id=open&amp;assigned_to_id=me)"/>
                        <LineBreak/>
                        <Run Text="　　空欄の場合は project={projectKey} のみで検索します。"/>
                    </TextBlock>
                </TextBox.ToolTip>
            </TextBox>

            <!-- ExtraParams (JiraOnPrem のみ任意・表示) -->
            <TextBlock Grid.Row="8" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="URL 追加パラメータ:"/>
            </TextBlock>
            <TextBox Grid.Row="8" Grid.Column="1"
                     Text="{Binding ExtraParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
                <TextBox.ToolTip>
                    <TextBlock>
                        <Run Text="URL クエリ文字列形式で追加するパラメータ。"/>
                        <LineBreak/>
                        <Run Text="例: fields=key,summary&amp;expand=changelog"/>
                        <LineBreak/>
                        <Run Text="URL 末尾に &amp; で連結されます。空欄の場合は何も追加されません。"/>
                    </TextBlock>
                </TextBox.ToolTip>
            </TextBox>

            <!-- MaxResults (Jira Cloud / JiraOnPrem 表示) -->
            <TextBlock Grid.Row="9" Grid.Column="0"
                       VerticalAlignment="Center" Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="Jira">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="最大取得件数:"/>
            </TextBlock>
            <TextBox Grid.Row="9" Grid.Column="1"
                     Text="{Binding MaxResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"
                     ToolTip="1回の API 呼び出しで取得する最大件数。0 は既定値（Jira Cloud: 100 / JiraOnPrem: 50）を使用。">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Provider}" Value="Jira">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Provider}" Value="JiraOnPrem">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- AutoRefreshOnOpen -->
            <CheckBox Grid.Row="10" Grid.Column="1"
                      Content="起動時に自動更新する"
                      IsChecked="{Binding AutoRefreshOnOpen, Mode=TwoWay}"
                      Margin="0,4,0,0"/>
        </Grid>

        <!-- 接続テスト行 -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="TestButton"
                    Content="接続テスト"
                    MinWidth="90"
                    IsEnabled="{Binding IsNotTesting}"
                    Click="OnTestConnectionClick"/>
            <!-- テスト中スピナー文字 -->
            <TextBlock Grid.Column="2"
                       Text="テスト中..."
                       Foreground="#FF666666"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsTesting,
                           Converter={StaticResource BoolVis}}"/>
            <!-- 結果ラベル: 成功=青 / エラー=赤 -->
            <TextBlock Grid.Column="2"
                       x:Name="TestResultLabel"
                       Text="{Binding TestResultText}"
                       FontWeight="Bold"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Visibility="{Binding TestResultVisible,
                           Converter={StaticResource BoolVis}}"
                       Foreground="{Binding TestSuccess,
                           Converter={StaticResource BoolToTestColor}}"/>
        </Grid>

        <!-- ログエリア -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="送信コマンド / レスポンス電文:"
                       Foreground="#FF3B3B3B"
                       FontSize="11"
                       Margin="0,0,0,4"/>
            <TextBox Grid.Row="1"
                     x:Name="TestLogBox"
                     Text="{Binding TestLog, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Courier New"
                     FontSize="11"
                     Background="#FFF8F8F8"
                     Foreground="#FF1A1A1A"
                     Padding="6,4"
                     AcceptsReturn="False"
                     FocusVisualStyle="{x:Null}"
                     MinHeight="48">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#FF0078D7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>

        <!-- ボタン -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="OkButton"
                    Content="OK"
                    MinWidth="80"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnOkClick"/>
            <Button Content="キャンセル"
                    IsCancel="True"
                    MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
