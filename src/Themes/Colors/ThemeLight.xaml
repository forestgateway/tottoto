<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Light theme colors -->
    <Color x:Key="AccentColor">#BBB8D9F5</Color>
    <Color x:Key="PanelBg">#FFF0F0F0</Color>
    <Color x:Key="HeaderBg">#FFE2E6EA</Color>
    <!-- 選択色を半透明にして下の行背景が透けるようにする -->
    <Color x:Key="RowSelected">#66B8D9F5</Color>

    <Color x:Key="WindowBg">#FFFFFFFF</Color>
    <Color x:Key="WindowFg">#FF1A1A1A</Color>
    <Color x:Key="SubText">#FF3A3A3A</Color>
    <Color x:Key="Border">#FFD0D5DC</Color>
    <Color x:Key="ChartBg">#FFFAFAFA</Color>

    <!-- Row / grid colors for light theme -->
    <Color x:Key="RowEven">#FFFFFFFF</Color>
    <Color x:Key="RowOdd">#FFF8F8F8</Color>
    <Color x:Key="GridLine">#FFE6E6E6</Color>
    <Color x:Key="WeekLine">#FFDCDCDC</Color>
    <Color x:Key="CalendarDayFg">#FF333333</Color>

    <!-- Calendar (month header) top strip for light theme -->
    <Color x:Key="CalendarTopBg">#FF222222</Color>
    <Color x:Key="CalendarTopFg">#FFFFFFFF</Color>
    <!-- Calendar day background and holiday shades -->
    <Color x:Key="CalendarDayBg">#FF444444</Color>
    <Color x:Key="CalendarHoliday1">#FF8888FF</Color>
    <Color x:Key="CalendarHoliday2">#FF8888FF</Color>

    <!-- ガントチャートの週末／祝日用ブラシ（Light テーマで以前の薄青色を維持する）参照されていないぽい -->
    <SolidColorBrush x:Key="WeekendBrush">#2FE8E8FF</SolidColorBrush>
    
    <SolidColorBrush x:Key="TaskHoliday2Brush">#FFEEEEFF</SolidColorBrush>  <!-- これが優先有効 -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBg}" />
    <!-- タスク行用の週末ブラシ（従来の薄青系を維持） -->
    <SolidColorBrush x:Key="TaskWeekendBrush">#FFE8E8FF</SolidColorBrush>

    <!-- ガント進捗ライン設定（テーマごとに上書き可能） -->
    <sys:Double x:Key="GanttProgressBarHeight">16</sys:Double>
    <sys:Double x:Key="GanttProgressCornerRadius">0</sys:Double>
    <sys:Double x:Key="GanttProgressHorizontalGap">1</sys:Double>

    <!-- ガントバーの既定色（テーマで上書き可能） -->
    <SolidColorBrush x:Key="GanttBarBrush" Color="#5F838383" />
    <!-- ステータス別の上書きも可能 -->
    <SolidColorBrush x:Key="GanttBarCompleteBrush" Color="#FFD4A0D4" />
    <SolidColorBrush x:Key="GanttBarWaitBrush"     Color="#FFFFB3B3" />
    <SolidColorBrush x:Key="GanttBarProgressBrush" Color="#FF90EE90" />
    <SolidColorBrush x:Key="GanttBarWarningBrush"  Color="#FF90E0E0" />
    <SolidColorBrush x:Key="GanttBarErrorBrush"    Color="#FFA0A0FF" />
    <SolidColorBrush x:Key="GanttBarOverBrush"     Color="#FF7070DD" />

    <!-- ステータス色（UI の他パーツでも使用可） -->
    <SolidColorBrush x:Key="StatusCompleteBrush" Color="#FFBB44BB" />
    <SolidColorBrush x:Key="StatusWaitBrush"     Color="#FF4488FF" />
    <SolidColorBrush x:Key="StatusProgressBrush" Color="#FF22BB22" />
    <SolidColorBrush x:Key="StatusWarningBrush"  Color="#FFFFAA00" />
    <SolidColorBrush x:Key="StatusErrorBrush"    Color="#FFFF3333" />
    <SolidColorBrush x:Key="StatusOverBrush"     Color="#FF990000" />

    <!-- Window 透過スタイル: ライトではデフォルトの枠付きウィンドウにする -->
    <Style x:Key="TransparentWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource WindowBgBrush}" />
        <Setter Property="WindowStyle" Value="None" />
        <!-- <Setter Property="WindowStyle" Value="SingleBorderWindow" />  -->
        <Setter Property="AllowsTransparency" Value="False" />
    </Style>

    
</ResourceDictionary>
