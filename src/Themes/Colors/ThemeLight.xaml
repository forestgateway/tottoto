<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme colors -->
    <Color x:Key="AccentColor">#BBB8D9F5</Color>
    <Color x:Key="PanelBg">#FFF0F0F0</Color>
    <Color x:Key="HeaderBg">#FFE2E6EA</Color>
    <!-- 選択色を半透明にして下の行背景が透けるようにする -->
    <Color x:Key="RowSelected">#66B8D9F5</Color>

    <Color x:Key="WindowBg">#FFFFFFFF</Color>
    <Color x:Key="WindowFg">#FF1A1A1A</Color>
    <Color x:Key="SubText">#FF3A3A3A</Color>
    <Color x:Key="Border">#FFD0D5DC</Color>
    <Color x:Key="ChartBg">#FFFAFAFA</Color>

    <!-- Row / grid colors for light theme -->
    <Color x:Key="RowEven">#FFFFFFFF</Color>
    <Color x:Key="RowOdd">#FFF8F8F8</Color>
    <Color x:Key="GridLine">#FFE6E6E6</Color>
    <Color x:Key="WeekLine">#FFDCDCDC</Color>
    <Color x:Key="CalendarDayFg">#FF333333</Color>

    <!-- Calendar (month header) top strip for light theme -->
    <Color x:Key="CalendarTopBg">#FF222222</Color>
    <Color x:Key="CalendarTopFg">#FFFFFFFF</Color>
    <!-- Calendar day background and holiday shades -->
    <Color x:Key="CalendarDayBg">#FF444444</Color>
    <Color x:Key="CalendarHoliday1">#FF8888FF</Color>
    <Color x:Key="CalendarHoliday2">#FF8888FF</Color>

    <!-- ガントチャートの週末／祝日用ブラシ（Light テーマで以前の薄青色を維持する） -->
    <SolidColorBrush x:Key="WeekendBrush">#2FE8E8FF</SolidColorBrush>
    <!-- タスク行用の週末ブラシ（従来の薄青系を維持） -->
    <SolidColorBrush x:Key="TaskWeekendBrush">#FFE8E8FF</SolidColorBrush>

</ResourceDictionary>
