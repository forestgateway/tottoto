<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ダーク グリーン カラーパレット -->
    <Color x:Key="AccentColor">#FF44EE88</Color>
    <Color x:Key="PanelBg">#D91A3A2A</Color>
    <Color x:Key="HeaderBg">#D91E5030</Color>
    <Color x:Key="RowSelected">#6644EE88</Color>

    <SolidColorBrush x:Key="AccentBrush"       Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="PanelBgBrush"      Color="{StaticResource PanelBg}"/>
    <SolidColorBrush x:Key="HeaderBgBrush"     Color="{StaticResource HeaderBg}"/>
    <SolidColorBrush x:Key="RowSelectedBrush"  Color="{StaticResource RowSelected}"/>
    <SolidColorBrush x:Key="WindowBgBrush"     Color="#D90A1B10"/>
    <SolidColorBrush x:Key="WindowFgBrush"     Color="#FFD0FFE8"/>
    <SolidColorBrush x:Key="SubTextBrush"      Color="#FFAACCBB"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#CC1E5030"/>
    <SolidColorBrush x:Key="ChartBgBrush"      Color="#D90A1E15"/>

</ResourceDictionary>
