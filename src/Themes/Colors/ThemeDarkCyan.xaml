<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ダーク シアン（デフォルト）カラーパレット -->
    <Color x:Key="AccentColor">#FF00C8FF</Color>
    <Color x:Key="PanelBg">#E61A2A3E</Color>
    <Color x:Key="HeaderBg">#E61E3050</Color>
    <Color x:Key="RowSelected">#6600C8FF</Color>

    <SolidColorBrush x:Key="AccentBrush"       Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="PanelBgBrush"      Color="{StaticResource PanelBg}"/>
    <SolidColorBrush x:Key="HeaderBgBrush"     Color="{StaticResource HeaderBg}"/>
    <SolidColorBrush x:Key="RowSelectedBrush"  Color="{StaticResource RowSelected}"/>
    <SolidColorBrush x:Key="WindowBgBrush"     Color="#E60D1B2A"/>
    <SolidColorBrush x:Key="WindowFgBrush"     Color="#FFD0E8FF"/>
    <SolidColorBrush x:Key="SubTextBrush"      Color="#FFAABBCC"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#CC1E3050"/>
    <SolidColorBrush x:Key="ChartBgBrush"      Color="#E60F1E30"/>

</ResourceDictionary>
