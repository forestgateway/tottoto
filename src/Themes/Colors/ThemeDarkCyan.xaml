<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Cyan (default) color palette -->
    <Color x:Key="AccentColor">#8F00C8FF</Color>
    <Color x:Key="PanelBg">#A91A2A3E</Color>
    <Color x:Key="HeaderBg">#D91E3050</Color>
    <Color x:Key="RowSelected">#6600C8FF</Color>

    <SolidColorBrush x:Key="AccentBrush"       Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="PanelBgBrush"      Color="{StaticResource PanelBg}"/>
    <SolidColorBrush x:Key="HeaderBgBrush"     Color="{StaticResource HeaderBg}"/>
    <SolidColorBrush x:Key="RowSelectedBrush"  Color="{StaticResource RowSelected}"/>
    <SolidColorBrush x:Key="WindowBgBrush"     Color="#A90D1B2A"/>
    <SolidColorBrush x:Key="WindowFgBrush"     Color="#9FD0E8FF"/>
    <SolidColorBrush x:Key="SubTextBrush"      Color="#9FAABBCC"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#7C1E3050"/>
    <SolidColorBrush x:Key="ChartBgBrush"      Color="#A90F1E30"/>

</ResourceDictionary>
