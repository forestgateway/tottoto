root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4

[*.xaml]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4

[*.csproj]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2

[*.sln]
end_of_line = lf

[*.{json,yml,yaml}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
